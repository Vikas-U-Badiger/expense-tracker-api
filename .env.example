# Expense Tracker API Environment Configuration

# Server Configuration
SERVER_PORT=8080
ENVIRONMENT=development

# Database Configuration
# Options: sqlite, postgres
DB_DRIVER=sqlite

# PostgreSQL Settings (only used if DB_DRIVER=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=expense_tracker
DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_TOKEN_EXPIRY=24
JWT_REFRESH_EXPIRY=168

# CORS Configuration
# Comma-separated list of allowed origins
ALLOW_ORIGINS=*
